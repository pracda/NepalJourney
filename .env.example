# Root-level env vars shared across apps (non-secret, build-time config).
# Service-specific secrets live in api/.env, apps/*/.env — never commit real values.

# Used by mobile/guide/web apps to reach the API
EXPO_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (public, safe for client bundles)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (public token, restricted by URL/bundle id in Mapbox dashboard)
EXPO_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=
