ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT (must match the secret Supabase Auth signs tokens with)
JWT_SECRET=
JWT_ALGORITHM=HS256

# Claude (orchestrator, Yatra, trip planner, translation context)
ANTHROPIC_API_KEY=

# OpenAI (Whisper STT, text-embedding-3-small for guide matching)
OPENAI_API_KEY=

# Redis (rate limiting, session caching)
REDIS_URL=redis://localhost:6379

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# Rate limits (requests per minute, per user)
RATE_LIMIT_REQUESTS_PER_MINUTE=60
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=10

# Sentry (optional in dev)
SENTRY_DSN=
